# ── Supabase ──────────────────────────────────────────────────
# Get these from your Supabase project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-publishable-key

# ── Razorpay ──────────────────────────────────────────────────
# Get from Razorpay Dashboard → Settings → API Keys
# Use rzp_test_... keys for testing, rzp_live_... for production

# Public key — safe to expose in frontend (VITE_ prefix = bundled into JS)
VITE_RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID

# Secret key — SERVER ONLY. Set this in Vercel Dashboard → Settings → Environment Variables
# NEVER put this in .env.local or commit it to git.
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── Supabase Service Role ─────────────────────────────────────
# Used by Vercel serverless functions (razorpay-verify.js) to bypass RLS.
# Get from Supabase → Settings → API → service_role key.
# SERVER ONLY — set in Vercel Dashboard, never in frontend.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── AI Smart Post Assistant ────────────────────────────────────
# Controls the ✨ Assist button in Create Post.
# Default is off (false) — turn on locally to test.
# Set VITE_AI_PROVIDER=mock to use rule-based engine (free, no API calls).
# Set VITE_AI_PROVIDER=real (Phase 3) to call the Anthropic API.
VITE_AI_ENABLED=false
VITE_AI_PROVIDER=mock

# ── Anthropic AI ───────────────────────────────────────────────
# Used by /api/ai-categorize (Phase 3 real provider) to auto-categorize posts.
# Get from console.anthropic.com → API Keys
# SERVER ONLY — set in Vercel Dashboard → Settings → Environment Variables
# Never prefix with VITE_ — never expose in frontend code.
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# ── Dev test personas (local only) ────────────────────────────
# One-click login for commerce/society testing. Never enable in production.
VITE_ENABLE_TEST_USERS=false
VITE_TEST_USER_PASSWORD=

# Demo phone OTP generator. Auto-enabled in dev and when Supabase is not configured.
# Set true only on a staging/testing build that needs demo-number OTPs.
VITE_ENABLE_DEMO_OTP=false
